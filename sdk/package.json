    "dev": "bun test --watch"
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.8",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "bun-types": "^1.3.6",
    "typescript": "^5.7.2"
  }
}
