{
  "name": "@polet-ai/sdk",
  "version": "0.1.0",
  "type": "module",
  "description": "Polet AI SDK - Intent JSON builder for AI agents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
