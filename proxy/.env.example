# ── Required ──────────────────────────────────────────────────────────────────

# Jupiter API key (get one at https://portal.jup.ag)
JUPITER_API_KEY=your_jupiter_api_key

# Solana RPC endpoint (devnet for demo)
SOLANA_RPC_URL=https://api.devnet.solana.com

# 64-byte tweetnacl Ed25519 secret key (hex) used to sign Ika gRPC SignedRequestData.
# Generate with: bun -e 'import nacl from "tweetnacl"; const kp = nacl.sign.keyPair(); console.log(Buffer.from(kp.secretKey).toString("hex"))'
POLET_IKA_SERVICE_KEYPAIR_HEX=

# ── Ika gas floor (set to 0 for pre-alpha — mock signer does not consume gas) ─

POLET_IKA_GAS_MIN_IKA_BASE_UNITS=0
POLET_IKA_GAS_MIN_SOL_LAMPORTS=0

# ── Optional ──────────────────────────────────────────────────────────────────

# Override proxy port (default: 3001)
# PORT=3001

# Override Ika gRPC endpoint (default: pre-alpha-dev-1.ika.ika-network.net:443)
# IKA_GRPC_URL=pre-alpha-dev-1.ika.ika-network.net:443

# Path to the managed Ika dWallet fixture (default: .polet/ika-managed-fixture.json)
# POLET_IKA_MANAGED_FIXTURE_PATH=.polet/ika-managed-fixture.json

# Path to the per-owner dWallet registry (default: .polet/ika-dwallets.json)
# POLET_IKA_REGISTRY_PATH=.polet/ika-dwallets.json

# Subsidy keypair used to fund Ika GasDeposit PDAs on behalf of users.
# Provide either inline base58 or a path to a JSON keypair file.
# POLET_IKA_SUBSIDY_KEYPAIR=<base58_secret>
# POLET_IKA_SUBSIDY_KEYPAIR_PATH=keys/subsidy-keypair.json

# Destination broadcast mode: auto | live | demo-memo | disabled (default: auto → demo-memo)
# POLET_DESTINATION_BROADCAST_MODE=demo-memo
